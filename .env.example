# Database (SQLAlchemy URL)
DATABASE_URL=sqlite+pysqlite:///./arctis_dev.db

# Fernet key for encrypting LLM keys at rest (generate with cryptography.fernet)
ARCTIS_ENCRYPTION_KEY=

# Optional: OpenAI when no tenant LLM key is stored
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Local Ollama fallback (when ARCTIS_USE_OLLAMA=true and no tenant key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:7b
ARCTIS_USE_OLLAMA=false

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional observability
SENTRY_DSN=
ENV=dev
